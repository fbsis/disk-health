PORT=3000
DATA_DIR=./data

SSH_HOST=192.168.0.10
SSH_PORT=22
SSH_USER=root
# Use SSH_PASSWORD or SSH_PRIVATE_KEY (path to key file). Prefer key auth.
SSH_PASSWORD=
SSH_PRIVATE_KEY=
SSH_PASSPHRASE=

# Commands on remote
LSBLK_PATH=lsblk
SMARTCTL_PATH=smartctl
SMARTCTL_USE_SUDO=false
# Optional: limit disks (regex applied to /dev/* name, e.g. ^sd|^nvme)
DISK_INCLUDE_REGEX=^(sd|nvme|hd)

# Optional: run before collecting (e.g. export PATH=...)
SSH_READY_COMMAND=

# Scheduler (daily at exact time)
SCHEDULE_ENABLED=false
SCHEDULE_DAILY_TIME=14:00
